{
  "rules": [
    { "kind": "matthews_corrcoef", "metricPattern": "matthews correlation coefficient|\\bmcc\\b" },
    { "kind": "top_k_accuracy", "metricPattern": "top[- ]?\\d+\\s*accuracy|top[- ]?k accuracy|top[- ]?\\d+\\s*acc" },
    { "kind": "accuracy", "metricPattern": "human performance|human accuracy|expert performance" },
    { "kind": "accuracy", "metricPattern": "\\bacc\\b|accuracy" },
    { "kind": "exact_match", "metricPattern": "exact match" },
    { "kind": "f1", "metricPattern": "\\bf1\\b|f1 score|macro[- ]?f\\b|macro f1|micro[- ]?f\\b|micro f1" },
    { "kind": "silhouette_score", "metricPattern": "average silhouette width|silhouette width|\\basw\\b|silhouette score" },
    { "kind": "normalized_mutual_info", "metricPattern": "normalized mutual information|\\bnmi\\b" },
    { "kind": "adjusted_rand_index", "metricPattern": "adjusted rand index|\\bari\\b" },
    { "kind": "average_bio_score", "metricPattern": "average bio|avgbio|avg bio" },
    { "kind": "batch_integration_score", "metricPattern": "batch integration score|batch mixing score" },
    { "kind": "principal_component_regression_score", "metricPattern": "principal component regression|\\bpcr\\b" },
    { "kind": "average_batch_score", "metricPattern": "average batch score|avg batch score" },
    { "kind": "bertscore_precision", "metricPattern": "^pbert(?:\\s*\\(idf\\))?$|bertscore precision" },
    { "kind": "bertscore_recall", "metricPattern": "^rbert(?:\\s*\\(idf\\))?$|bertscore recall" },
    { "kind": "bertscore_f1", "metricPattern": "^fbert(?:\\s*\\(idf\\))?$|bertscore f1" },
    { "kind": "mse", "metricPattern": "\\bmse\\b|mean squared error" },
    { "kind": "pearson", "metricPattern": "pearson( correlation)?" },
    { "kind": "spearman", "metricPattern": "spearman('|’)?s?( rank)? correlation|spearman" },
    { "kind": "kendall_tau", "metricPattern": "kendall('|’)?s?( rank)? tau|kendall tau" },
    { "kind": "average_precision", "metricPattern": "average precision|auprc|pr auc|auc-pr" },
    { "kind": "auc", "metricPattern": "roc-auc|auroc|\\bauc\\b", "excludeMetricPattern": "pr|average precision" },
    { "kind": "brier_score", "metricPattern": "brier" },
    { "kind": "expected_calibration_error", "metricPattern": "\\bece\\b|expected calibration error|calibration error" },
    { "kind": "negative_log_likelihood", "metricPattern": "negative log likelihood|\\bnll\\b|cross entropy|cross-entropy|log loss" },
    { "kind": "perplexity", "metricPattern": "perplexity|\\bppl\\b", "excludeMetricPattern": "path length|perceptual path length" },
    { "kind": "precision_at_k", "metricPattern": "precision@|precision at k|precision at \\d+" },
    { "kind": "precision", "metricPattern": "precision", "excludeMetricPattern": "average precision|map" },
    { "kind": "recall_at_k", "metricPattern": "recall@|recall at k|recall at \\d+|\\btr@\\d+\\b|\\bir@\\d+\\b|text retrieval.*@\\d+|image retrieval.*@\\d+" },
    { "kind": "recall", "metricPattern": "recall" },
    { "kind": "iou", "metricPattern": "\\biou\\b|intersection over union" },
    { "kind": "fid", "metricPattern": "\\bfid\\b|frechet inception distance" },
    { "kind": "psnr", "metricPattern": "\\bpsnr\\b|peak signal-to-noise ratio" },
    { "kind": "ssim", "metricPattern": "\\bssim\\b|structural similarity" },
    { "kind": "mae", "metricPattern": "\\bmae\\b" },
    { "kind": "rmse", "metricPattern": "\\brmse\\b" },
    { "kind": "mape", "metricPattern": "\\bmape\\b" },
    { "kind": "smape", "metricPattern": "smape|s-mape" },
    { "kind": "dtw", "metricPattern": "\\bdtw\\b|dynamic time warping" },
    { "kind": "edit_similarity", "metricPattern": "edit sim|edit similarity|\\banls\\b|average normalized levenshtein similarity" },
    { "kind": "token_overlap_recall", "metricPattern": "^iter$|inverse translation edit rate" },
    { "kind": "sigmoid_score_average", "metricPattern": "^ruse$|ruse\\b" },
    { "kind": "greedy_token_similarity", "metricPattern": "^yisi(?:-|\\s)?1$|^yisi\\b" },
    { "kind": "relevant_noise_sensitivity", "metricPattern": "relevant noise sensitivity|ns\\(i\\)|noise sensitivity i" },
    { "kind": "irrelevant_noise_sensitivity", "metricPattern": "irrelevant noise sensitivity|ns\\(ii\\)|noise sensitivity ii" },
    { "kind": "wer", "metricPattern": "word error rate|\\bwer\\b" },
    { "kind": "cer", "metricPattern": "character error rate|\\bcer\\b" },
    { "kind": "average_return", "metricPattern": "reward curve|episode reward|average total reward|average reward|average return|cumulative reward|return\\b" },
    { "kind": "average_max_state_value", "metricPattern": "average maximum predicted action[- ]?value|max(?:imum)? predicted q[- ]?value|max q[- ]?value" },
    { "kind": "success_rate", "metricPattern": "success rate|success@|solve rate|solve@" },
    { "kind": "pass_at_k", "metricPattern": "pass@|pass at k|pass at \\d+" },
    { "kind": "normalized_score", "metricPattern": "average normalized score|human normalized score|normalized score" },
    { "kind": "expected_entropy", "metricPattern": "expected entropy" },
    { "kind": "speedup_ratio", "metricPattern": "wall-clock speedup|speedup|throughput gain|latency reduction" },
    { "kind": "runtime_seconds", "metricPattern": "wall-clock time per epoch|time per epoch|wall-clock training time|training time|runtime|latency" },
    { "kind": "amino_acid_recovery", "metricPattern": "amino acid recovery|\\baar\\b" },
    { "kind": "rank_percent", "metricPattern": "rank %|rank percent|rank percentile|percentile rank" },
    { "kind": "winning_count", "metricPattern": "wini?ng[- ]?counts?" },
    { "kind": "path_length", "metricPattern": "path length|perceptual path length|\\bppl\\b" },
    { "kind": "judge_score_aggregate", "metricPattern": "faithfulness|factuality|utility|correctness|helpfulness|groundedness|relevance|coherence|fluency|hallucination|self[- ]?knowledge|context utilization|overall assessment|completeness" },
    { "kind": "rmsd", "metricPattern": "rmsd|root mean square deviation|root-mean-square deviation" },
    { "kind": "ndcg", "metricPattern": "ndcg" },
    { "kind": "mrr", "metricPattern": "\\bmrr\\b|mean reciprocal rank" },
    { "kind": "hit_rate", "metricPattern": "^hr$|^(hit rate|hit ratio)$|hit@|hr@" },
    { "kind": "library_metric", "metricPattern": "bleu|rouge|bertscore|cider|spice" }
  ],
